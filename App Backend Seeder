import Foundation

// MARK: - Configure your API base URL here
enum Endpoints {
    static let baseURL = URL(string: "https://YOUR_API_DOMAIN_HERE.com")!

    static var plants: URL { baseURL.appendingPathComponent("/plants") }
    static var plantPartsBulk: URL { baseURL.appendingPathComponent("/plant-parts/bulk") }
    static var quizQuestionsBulk: URL { baseURL.appendingPathComponent("/quiz-questions/bulk") }
}

// MARK: - Models (Request/Response)

// Create Plant request body
struct PlantCreateRequest: Codable {
    let name: String
    let scientific_name: String
    let description: String
    let fun_facts: [String]
    let image_url: String
    let color: String
}

// Plant response (must include id returned by API)
struct Plant: Codable {
    let id: String
    let name: String
    let scientific_name: String?
    let description: String?
    let fun_facts: [String]?
    let image_url: String?
    let color: String?
}

// PlantPart bulk item
struct PlantPartCreateRequest: Codable {
    let plant_id: String
    let part_name: String
    let description: String
    let fun_fact: String
    let function: String
}

// QuizQuestion bulk item
struct QuizQuestionCreateRequest: Codable {
    let plant_id: String?          // optional because your JS code had some without plant_id
    let question: String
    let options: [String]
    let correct_answer: String
    let difficulty: String
    let created_by_teacher: Bool
}

// MARK: - Simple HTTP Client (no base44)

final class APIClient {
    private let session: URLSession
    private let encoder = JSONEncoder()
    private let decoder = JSONDecoder()

    init(session: URLSession = .shared) {
        self.session = session
    }

    func postJSON<T: Codable, R: Codable>(url: URL, body: T) async throws -> R {
        var request = URLRequest(url: url)
        request.httpMethod = "POST"
        request.setValue("application/json", forHTTPHeaderField: "Content-Type")
        request.httpBody = try encoder.encode(body)

        let (data, response) = try await session.data(for: request)

        guard let http = response as? HTTPURLResponse else {
            throw URLError(.badServerResponse)
        }
        guard (200...299).contains(http.statusCode) else {
            let serverText = String(data: data, encoding: .utf8) ?? "<no body>"
            throw NSError(domain: "APIError", code: http.statusCode, userInfo: [
                NSLocalizedDescriptionKey: "HTTP \(http.statusCode): \(serverText)"
            ])
        }

        return try decoder.decode(R.self, from: data)
    }

    func postJSONNoResponse<T: Codable>(url: URL, body: T) async throws {
        var request = URLRequest(url: url)
        request.httpMethod = "POST"
        request.setValue("application/json", forHTTPHeaderField: "Content-Type")
        request.httpBody = try encoder.encode(body)

        let (data, response) = try await session.data(for: request)

        guard let http = response as? HTTPURLResponse else {
            throw URLError(.badServerResponse)
        }
        guard (200...299).contains(http.statusCode) else {
            let serverText = String(data: data, encoding: .utf8) ?? "<no body>"
            throw NSError(domain: "APIError", code: http.statusCode, userInfo: [
                NSLocalizedDescriptionKey: "HTTP \(http.statusCode): \(serverText)"
            ])
        }
    }
}

